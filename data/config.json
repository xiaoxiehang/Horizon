    "overview_position": "first",
    "platform": "dingtalk",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msgtype": "markdown",
      "markdown": {
        "title": "发布 | Horizon 每日速递 #{date}",
        "text": "## 发布 | Horizon 每日速递 - #{date}\n\n#{news_list}\n\n---\n\n[🔗 查看完整日报](https://xiaoxiehang.github.io/Horizon/)"
