{
    "version": "1.0",
    "ai": {
        "provider": "anthropic",
        "base_url": "https://coding.dashscope.aliyuncs.com/apps/anthropic",
        "model": "qwen3.7-plus",
        "api_key_env": "ANTHROPIC_API_KEY",
        "temperature": 0.3,
        "max_tokens": 4096,
        "throttle_sec": 0,
        "analysis_concurrency": 5,
        "enrichment_concurrency": 5,
        "languages": ["zh"]
    },
    "email": {
        "enabled": false,
        "smtp_server": "",
        "smtp_port": 465,
        "imap_server": "",
        "imap_port": 993,
        "email_address": "",
        "sender_name": "Horizon Daily",
        "subscribe_keyword": "SUBSCRIBE",
        "unsubscribe_keyword": "UNSUBSCRIBE"
    },
    "sources": {
        "github": [
            {
                "type": "repo_releases",
                "owner": "astral-sh",
                "repo": "uv",
                "enabled": true
            }
        ],
        "hackernews": {
            "enabled": true,
            "fetch_top_stories": 15,
            "min_score": 100
        },
        "rss": [
            {
                "name": "TechCrunch",
                "url": "https://techcrunch.com/feed/",
                "enabled": true,
                "category": "tech"
            },
            {
                "name": "The Verge",
                "url": "https://www.theverge.com/rss/index.xml",
                "enabled": true,
                "category": "tech"
            },
            {
                "name": "Wired",
                "url": "https://www.wired.com/feed/rss",
                "enabled": true,
                "category": "tech"
            }
        ],
        "reddit": {
            "enabled": false
        },
        "twitter": {
            "enabled": false
        }
    },
    "filtering": {
        "ai_score_threshold": 6.0,
        "time_window_hours": 24,
        "max_items": null,
        "timeout_seconds": 1200
    },
    "webhook": {
        "enabled": true,
        "url_env": "DINGTALK_WEBHOOK_URL",
        "delivery": "summary",
        "overview_position": "first",
        "platform": "dingtalk",
        "layout": "markdown",
        "fallback_layout": "markdown",
        "languages": ["zh"],
        "request_body": {
            "msgtype": "markdown",
            "markdown": {
                "title": "发布 | Horizon 每日速递 #{date}",
                "text": "## 发布 | Horizon 每日速递 - #{date}\n\n#{news_list}\n\n---\n\n[🔗 查看完整日报](https://xiaoxiehang.github.io/Horizon/)"
            }
        }
    }
}
